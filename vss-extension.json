{
    "manifestVersion": 1,
    "id": "asciidoc",
    "name": "AsciiDoc PR Viewer",
    "version": "1.0.56",
    "publisher": "ajeckmans",
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "scopes": [
        "vso.code",
        "vso.threads_full"
    ],
    "description": "Seamlessly render and interact with AsciiDoc files natively in Pull Requests and the Repository Hub.",
    "icons": {
        "default": "images/asciidoc-icon.png"
    },
    "repository": {
        "type": "git",
        "uri": "https://github.com/ajeckmans/azuredevops-asciidoc"
    },
    "content": {
        "details": {
            "path": "README.md"
        }
    },
    "public": false,
    "categories": [
        "Azure Repos"
    ],
    "contributions": [
        {
            "id": "asciidoc-pr-tab",
            "type": "ms.vss-web.tab",
            "targets": [
                "ms.vss-code-web.pr-tabs"
            ],
            "properties": {
                "name": "AsciiDoc",
                "uri": "dist/index.html"
            }
        },
        {
            "id": "asciidoc-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-code-web.code-hub-group"
            ],
            "properties": {
                "name": "AsciiDoc",
                "uri": "dist/hub.html",
                "icon": "asset://images/asciidoc-icon.png"
            }
        },
        {
            "id": "asciidoc-preview-action",
            "type": "ms.vss-web.action",
            "targets": [
                "ms.vss-code-web.pr-file-action-menu",
                "ms.vss-code-web.pull-request-action-menu",
                "ms.vss-code-web.change-list-item-menu",
                "ms.vss-code-web.source-tree-item-menu"
            ],
            "properties": {
                "text": "Preview AsciiDoc",
                "title": "Preview this AsciiDoc file in the AsciiDoc tab",
                "icon": "images/asciidoc-icon.png",
                "uri": "dist/action.html"
            }
        },
        {
            "id": "asciidoc-settings",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.collection-admin-hub-group"
            ],
            "properties": {
                "name": "AsciiDoc Settings",
                "uri": "dist/settings.html"
            }
        }
    ],
    "files": [
        {
            "path": "dist",
            "addressable": true
        },
        {
            "path": "images",
            "addressable": true
        }
    ]
}
