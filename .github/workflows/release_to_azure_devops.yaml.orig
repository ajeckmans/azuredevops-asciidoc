name: Release to Azure DevOps Marketplace

on:
  workflow_dispatch:
  push:
    branches:
      - 'main'
    tags:
      - 'v*'
  pull_request:
    branches:
      - '**'

jobs:
  package-and-publish:
    permissions:
      contents: write
    if: github.event_name == 'workflow_dispatch' || github.event_name == 'pull_request' || (github.event_name == 'push' && (github.ref == 'refs/heads/main' || startsWith(github.ref, 'refs/tags/v')))
    runs-on: ubuntu-latest
    defaults:
      run:
        shell: bash -e {0}
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js environment
        uses: actions/setup-node@v4
        with:
          node-version: '24'

      - name: Install tfx-cli
        run: npm install -g tfx-cli

      - name: Set version
        run: |
          BASE_VERSION=$(grep -o '"version": *"[^"]*"' vss-extension.json | grep -o '[0-9.]*' | head -1)

          if [[ "${{ github.ref }}" == "refs/heads/main" ]]; then
            TARGET_EXT_ID="asciidoc"
            EXT_PUBLIC="true"
            EXT_NAME="AsciiDoc PR Viewer"
          elif [[ "${{ github.event_name }}" == "pull_request" ]]; then
            TARGET_EXT_ID="asciidoc-private"
            EXT_PUBLIC="false"
            EXT_NAME="AsciiDoc PR Viewer (Private)"
          else
            TARGET_EXT_ID="asciidoc"
            EXT_PUBLIC="false"
            EXT_NAME="AsciiDoc PR Viewer"
          fi

          if [[ "${{ github.ref }}" == "refs/heads/main" || "${{ github.event_name }}" == "pull_request" ]]; then
            PUBLISHED_JSON=$(tfx extension show --publisher ajeckmans --extension-id asciidoc --token ${{ secrets.AZURE_DEVOPS_PAT }} --json || echo "{}")
            PUBLISHED_VERSION=$(echo "$PUBLISHED_JSON" | jq -r '.versions[0].version')

            if [ -z "$PUBLISHED_VERSION" ] || [ "$PUBLISHED_VERSION" == "null" ]; then
              PUBLISHED_VERSION=$BASE_VERSION
            fi

            IFS='.' read -ra V_PARTS <<< "$PUBLISHED_VERSION"

            if [[ "${{ github.event_name }}" == "pull_request" ]]; then
              EXT_VERSION="${V_PARTS[0]}.${V_PARTS[1]}.${V_PARTS[2]}.${{ github.run_number }}"
            else
              NEXT_PATCH=$((${V_PARTS[2]} + 1))
              EXT_VERSION="${V_PARTS[0]}.${V_PARTS[1]}.${NEXT_PATCH}"
            fi
          else
            EXT_VERSION="${BASE_VERSION}.${{ github.run_number }}"
          fi

          echo "EXT_ID=$TARGET_EXT_ID" >> $GITHUB_ENV
          echo "EXT_PUBLIC=$EXT_PUBLIC" >> $GITHUB_ENV
          echo "EXT_NAME=$EXT_NAME" >> $GITHUB_ENV
          echo "EXT_VERSION=$EXT_VERSION" >> $GITHUB_ENV

      - name: Restore npm packages
        run: npm ci --legacy-peer-deps

      - name: Run Tests
        run: npm run test

      - name: Build task bundle
        run: npm run build

      - name: Package Extension
        run: |
          tfx extension create --manifests vss-extension.json --override "{\"version\": \"${{ env.EXT_VERSION }}\", \"id\": \"${{ env.EXT_ID }}\", \"public\": ${{ env.EXT_PUBLIC }}, \"name\": \"${{ env.EXT_NAME }}\"}" --output-path ./dist/

      - name: Publish Extension
        if: github.ref == 'refs/heads/main' || github.event_name == 'pull_request'
        run: |
          tfx extension publish --vsix dist/ajeckmans.${{ env.EXT_ID }}-${{ env.EXT_VERSION }}.vsix --token ${{ secrets.AZURE_DEVOPS_PAT }}

      - name: Create GitHub Release
        if: github.ref == 'refs/heads/main'
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh release create "v${{ env.EXT_VERSION }}.${{ github.run_number }}" dist/ajeckmans.asciidoc-${{ env.EXT_VERSION }}.vsix --title "Release v${{ env.EXT_VERSION }} (Build ${{ github.run_number }})" --generate-notes
